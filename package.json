{
  "name": "maintainerr",
  "version": "3.15.2",
  "private": true,
  "packageManager": "yarn@4.11.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/maintainerr/Maintainerr.git"
  },
  "license": "MIT",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:fresh-setup": "VITE_BYPASS_MEDIA_SERVER_SETUP_GUARD=false turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "format:changed": "node tools/format-changed.mjs",
    "format:check": "turbo format:check",
    "knip": "knip",
    "check-types": "turbo check-types",
    "test": "turbo test --",
    "test:watch": "turbo test:watch"
  },
  "workspaces": [
    "apps/ui",
    "apps/server",
    "packages/*"
  ],
  "engines": {
    "node": "^22.13.0 || >=24.11.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^26.0.0",
    "knip": "^6.17.2",
    "semantic-release": "^25.0.5",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3"
  },
  "release": {
    "plugins": [
      "@semantic-release/commit-analyzer",
      [
        "@semantic-release/changelog",
        {
          "changelogFile": "CHANGELOG.md"
        }
      ],
      "@semantic-release/npm",
      [
        "@semantic-release/exec",
        {
          "generateNotesCmd": "NEXT_RELEASE_VERSION=\"${nextRelease.version}\" LAST_RELEASE_GITTAG=\"${lastRelease.gitTag}\" NEXT_RELEASE_GITHEAD=\"${nextRelease.gitHead}\" node tools/generate-release-notes.mjs",
          "prepareCmd": "yarn --cwd apps/server version ${nextRelease.version} && yarn --cwd apps/ui version ${nextRelease.version}"
        }
      ],
      [
        "@semantic-release/git",
        {
          "assets": [
            "package.json",
            "apps/server/package.json",
            "apps/ui/package.json",
            "CHANGELOG.md"
          ],
          "message": "chore(release): ${nextRelease.version}"
        }
      ],
      [
        "@semantic-release/github",
        {
          "addReleases": "bottom"
        }
      ]
    ],
    "branches": [
      "main"
    ],
    "npmPublish": false,
    "publish": [
      "@semantic-release/github"
    ]
  },
  "resolutions": {
    "dompurify": "3.4.11",
    "multer": "2.2.0",
    "picomatch": ">=4.0.4",
    "postcss": ">=8.5.10",
    "lodash": ">=4.18.0",
    "lodash-es": ">=4.18.0",
    "node-gyp": "11.2.0",
    "minimatch@^9.0.4": "9.0.9",
    "yaml@^1.10.0": "1.10.3",
    "ajv@8.17.1": "8.20.0",
    "undici@^6.19.5": "6.27.0",
    "undici@^7.0.0": "7.28.0",
    "undici@^7.25.0": "7.28.0",
    "uuid@^9.0.1": "11.1.1"
  }
}
