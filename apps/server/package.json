{
  "name": "@maintainerr/server",
  "version": "3.17.1",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "nest:build": "nest build",
    "start": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "test": "yarn test:runtime:jellyfin-sdk && jest",
    "test:runtime:jellyfin-sdk": "node ./test/jellyfin-sdk-runtime-smoke.cjs",
    "test:clear": "jest --clearCache",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "yarn node --inspect-brk $(yarn bin jest) --runInBand",
    "test:e2e": "yarn exec tsc -p ./test/tsconfig.e2e.json && node ./dist-test/test/rules-test-matrix.e2e.js",
    "migration:create": "yarn exec typeorm-ts-node-commonjs migration:create",
    "migration:run": "yarn exec typeorm-ts-node-commonjs migration:run -d ./src/datasource-config.ts",
    "migration:revert": "yarn exec typeorm-ts-node-commonjs migration:revert -d ./src/datasource-config.ts",
    "migration:generate": "yarn exec typeorm-ts-node-commonjs migration:generate --dataSource ./src/datasource-config.ts -p",
    "migration:show": "yarn exec typeorm-ts-node-commonjs migration:show --dataSource ./src/datasource-config.ts"
  },
  "dependencies": {
    "@jellyfin/sdk": "^0.13.0",
    "@maintainerr/contracts": "workspace:^",
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/serve-static": "^5.0.5",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/typeorm": "^11.0.3",
    "@octokit/core": "^5.2.0",
    "@octokit/plugin-throttling": "^8.2.0",
    "@tygra/nestjs-graceful-shutdown": "^2.0.0",
    "@types/express": "^5.0.6",
    "axios": "^1.18.1",
    "axios-retry": "^4.5.0",
    "better-sqlite3": "^12.11.1",
    "canvas": "^3.2.3",
    "chalk": "^4.1.2",
    "cron-validator": "^1.4.0",
    "date-fns": "^4.4.0",
    "email-templates": "13.0.1",
    "http-terminator": "^3.2.0",
    "lodash": "^4.18.1",
    "mime-types": "^3.0.2",
    "nestjs-zod": "^5.4.0",
    "node-cache": "^5.1.2",
    "nodemailer": "9.0.3",
    "octokit": "^3.2.2",
    "openpgp": "^6.3.1",
    "read-last-lines": "^1.8.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.35.3",
    "typeorm": "^1.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "xml2js": "^0.6.2",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.5.0",
    "@nestjs/cli": "^11.0.24",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.28",
    "@suites/di.nestjs": "^3.1.0",
    "@suites/doubles.jest": "^3.1.0",
    "@suites/unit": "^3.1.1",
    "@swc/core": "^1.15.43",
    "@swc/jest": "^0.2.39",
    "@types/email-templates": "^10.0.4",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/mime-types": "^3",
    "@types/node": "^26",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.4",
    "jest": "^30.4.2",
    "prettier": "^3.9.5",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "@swc/jest",
        {
          "jsc": {
            "target": "es2022",
            "parser": {
              "syntax": "typescript",
              "decorators": true
            },
            "transform": {
              "legacyDecorator": true,
              "decoratorMetadata": true
            },
            "keepClassNames": true
          },
          "module": {
            "type": "commonjs"
          }
        }
      ]
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(@octokit|octokit|bottleneck|@jellyfin/sdk|@faker-js/faker)/)",
      "/packages/contracts/dist/"
    ],
    "collectCoverageFrom": [
      "**/*.ts"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/../test/jest.setup.ts"
    ]
  }
}
